# ============================================================
# AHMAD & CO. — Environment Variables Template
# ============================================================
# ✅ YEH FILE GITHUB PAR PUSH KARO (koi real values nahi hain)
# ⚠️  .env copy karo, real values bharo, .env ko KABHI push mat karo
# ============================================================

# ── Gmail Configuration ─────────────────────────────────────
EMAIL_USER=your-gmail@gmail.com

# Gmail App Password (NOT your normal password)
# Get it: https://myaccount.google.com/apppasswords
# 2-Step Verification must be ON first
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx

# ── Notification Target ─────────────────────────────────────
# Who receives lead notifications
NOTIFY_EMAIL=your-notify-email@gmail.com

# ── Admin Token ─────────────────────────────────────────────
# Must be a strong random string — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=replace-with-64-char-hex-string

# ── Server ──────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=https://ahmadco.tech

# ── Node Environment ────────────────────────────────────────
NODE_ENV=production
