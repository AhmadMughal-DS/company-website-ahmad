# AHMAD & CO. — .gitignore
# ============================================================

# ── Secrets & Environment (NEVER COMMIT!) ───────────────────
.env
.env.local
.env.production
.env.staging
.env.*.local
*.pem
*.key
*.p12
*.pfx
secrets/

# ── Backend data (private leads) ────────────────────────────
backend/data/
backend/data/leads.json

# ── Node modules ────────────────────────────────────────────
node_modules/
backend/node_modules/

# ── Build artifacts ─────────────────────────────────────────
dist/
build/
.cache/

# ── Logs ────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# ── OS files ────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE / Editor ────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo

# ── Docker override (local only) ────────────────────────────
docker-compose.override.yml
docker-compose.local.yml

# ── Test coverage ───────────────────────────────────────────
coverage/
.nyc_output/
